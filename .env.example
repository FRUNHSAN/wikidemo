# Wiki.js 环境配置文件
# 复制此文件为 .env 并修改相应的值

# ==========================================
# 数据库配置
# ==========================================
POSTGRES_DB=wikidb
POSTGRES_USER=wikiuser
POSTGRES_PASSWORD=wikipassword123

# ==========================================
# Wiki.js配置
# ==========================================
ADMIN_EMAIL=admin@example.com

# ==========================================
# Git同步配置（可选）
# ==========================================
# 启用Git同步：true/false
GIT_SYNC_ENABLED=false

# Git仓库地址（GitHub/Gitee等）
GIT_REPO_URL=https://github.com/yourusername/wiki-notes.git

# Git分支
GIT_BRANCH=main

# Git用户名
GIT_USERNAME=your-username

# Git Token（推荐使用Personal Access Token）
# GitHub: https://github.com/settings/tokens
# Gitee: https://gitee.com/profile/personal_access_tokens
GIT_TOKEN=your-git-token-here

# 同步间隔（分钟）
GIT_SYNC_INTERVAL=30

# ==========================================
# API配置（用于插件系统）
# ==========================================
# Wiki.js API Token（在管理后台生成）
WIKI_API_TOKEN=your-wiki-api-token

# OpenAI API Key（用于AI功能，可选）
OPENAI_API_KEY=sk-your-openai-key

# ==========================================
# Nginx配置
# ==========================================
NGINX_SERVER_NAME=localhost

# ==========================================
# Docker网络配置（IPv6）
# ==========================================
DOCKER_IPV6_SUBNET=fd00:wiki:net::/64
DOCKER_IPV4_SUBNET=172.20.0.0/16
